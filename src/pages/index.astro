---

<MainLayout
  title="Keystone renovations | private homeowner focus"
  description="Keystone Renovations helps private homeowners bring renovation visions to life through thoughtful planning, high-quality finishes, and professionally managed delivery."
>
  <main>
    <section class="hero hero--v3" id="top">
      <div class="hero__backdrop"></div>
      <div class="shell">
        <header class="site-header" data-animate="fade-down">
          <a class="brand" href="#top" aria-label="Keystone Renovations home">
            <img
              src="https://storage.googleapis.com/shutquote/keystone-logo%20Large.png"
              alt="Keystone Renovations"
            />
          </a>

          <nav class="site-nav" aria-label="Primary navigation">
            {navItems.map((item) => (
              <a href={item.href}>{item.label}</a>
            ))}
          </nav>

          <div class="site-header__actions">
            <a class="button button--solid" href="#contact">Book a consultation</a>
            <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open navigation menu">
              <span></span>
              <span></span>
              <span></span>
            </button>
          </div>

          <div class="mobile-menu" id="mobile-menu" hidden>
            <nav class="mobile-menu__nav" aria-label="Mobile navigation">
              {navItems.map((item) => (
                <a href={item.href}>{item.label}</a>
              ))}
            </nav>
            <a class="button button--solid mobile-menu__cta" href="#contact">Book a consultation</a>
          </div>
        </header>

        <div class="hero__grid">
          <div class="hero__content" data-animate="fade-up">
            <p class="eyebrow">East Midlands pre-sale renovations</p>
            <h1>Maximise your sale price with expert pre-sale renovations.</h1>
            <p class="hero__lede">
              High-impact, fast-turnaround property updates across the East Midlands. We help homeowners and
              agents reduce time on the market and increase buyer confidence.
            </p>

            <div class="hero__actions">
              <a class="button button--solid" href="#projects">View our projects</a>
              <a class="button button--ghost" href="#contact">Get a quote</a>
            </div>
          </div>

          <aside class="hero-card" data-animate="fade-left">
            <span class="hero-card__label">The keystone touch</span>
            <h2>Renovations done with clarity, care, and a sharper eye for detail.</h2>
            <p>
              We help homeowners shape more functional, more beautiful interiors without losing sight
              of design intent, comfort, or long-term value.
            </p>
            <div class="hero-card__stats">
              {stats.map((item) => (
                <div class="hero-stat">
                  <strong>{item.value}</strong>
                  <span>{item.label}</span>
                </div>
              ))}
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="value-strip">
      <div class="shell value-strip__grid">
        {valueProps.map((item, index) => (
          <article class="value-card" data-animate="fade-up" style={`transition-delay:${index * 120}ms`}>
