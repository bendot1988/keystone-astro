    </section>

    <section class="section section--light intro">
      <div class="shell intro__grid">
        <div class="intro__copy" data-animate="fade-up">
          <p class="section-kicker">About keystone</p>
          <h2>Making ambitious home renovations feel structured and achievable.</h2>
          <p>
            Keystone Renovations works with private homeowners who want more than a superficial
            update. We help shape renovation schemes that improve how a home works, feels, and
            presents itself every day.
          </p>
          <p>
            Whether the goal is a better kitchen layout, a calmer bathroom, or a full interior
            refresh, our process combines practical planning with a design-conscious finish. The
            result is a home that feels resolved rather than simply altered.
          </p>
        </div>

        <div class="intro__media" data-animate="fade-left">
          <img
            src="https://images.unsplash.com/photo-1600121848594-d8644e57abab?auto=format&fit=crop&q=80&w=1400"
            alt="Refined modern interior with carefully balanced materials"
            loading="lazy"
          />
        </div>
      </div>
    </section>

    <section class="section section--soft services" id="services">
      <div class="shell">
        <div class="section-heading section-heading--left" data-animate="fade-up">
          <p class="section-kicker">Services</p>
          <h2>Professional renovation services shaped around real homes.</h2>
          <p>
            We focus on high-value interior improvements that elevate both everyday living and the
            overall character of the property.
          </p>
        </div>

        <div class="services__grid">
          {services.map((service, index) => (
            <article class="service-card" data-animate="fade-up" style={`transition-delay:${index * 110}ms`}>
              <span class="service-card__number">0{index + 1}</span>
              <h3>{service.title}</h3>
              <p>{service.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--light process">
      <div class="shell">
        <div class="section-heading" data-animate="fade-up">
          <p class="section-kicker">Process</p>
          <h2>A cleaner renovation journey from first conversation to final finish.</h2>
        </div>

        <div class="process__grid">
          {processSteps.map((step, index) => (
            <article class="process-card" data-animate="fade-up" style={`transition-delay:${index * 120}ms`}>
              <span class="process-card__step">{step.number}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </article>
          ))}
        </div>
