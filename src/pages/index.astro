        </div>
      </div>
    </section>

    <section class="section section--light projects" id="projects">
      <div class="shell">
        <div class="section-heading section-heading--left" data-animate="fade-up">
          <p class="section-kicker">Selected work</p>
          <h2>Recent project directions that reflect our renovation approach.</h2>
        </div>

        <div class="projects__grid">
          {projects.map((project, index) => (
            <article class="project-card project-card--stacked" data-animate="fade-up" style={`transition-delay:${index * 120}ms`}>
              <img src={project.image} alt={project.title} loading="lazy" />
              <div class="project-card__body">
                <span class="project-card__tag">{project.tag}</span>
                <h3>{project.title}</h3>
                <p>{project.summary}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--soft testimonials">
      <div class="shell">
        <div class="section-heading" data-animate="fade-up">
          <p class="section-kicker">Client perspective</p>
          <h2>What homeowners value about the process.</h2>
        </div>

        <div class="testimonials__grid">
          {testimonials.map((item, index) => (
            <blockquote class="testimonial-card" data-animate="fade-up" style={`transition-delay:${index * 140}ms`}>
              <p>“{item.quote}”</p>
              <footer>{item.author}</footer>
            </blockquote>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--dark cta" id="contact">
      <div class="shell cta__panel" data-animate="fade-up">
        <div>
          <p class="section-kicker section-kicker--light">Contact</p>
          <h2>Ready to talk through your renovation plans?</h2>
          <p>
            If you are planning a kitchen, bathroom, or wider interior transformation, we can help
            shape the project into something practical, refined, and well managed from the outset.
          </p>
        </div>

        <div class="contact-card">
          <a href="tel:07549919442">07549 919 442</a>
          <a href="mailto:hello@keystonerenovations.co.uk">hello@keystonerenovations.co.uk</a>
          <a href="#projects">View recent project direction</a>
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <div class="shell site-footer__grid">
        <div class="site-footer__brand">
          <img
            src="https://storage.googleapis.com/shutquote/keystone-logo%20Large.png"
            alt="Keystone Renovations"
          />
          <p>
            Bringing renovation visions to life for homeowners who want practical improvements and a
            more resolved, design-conscious finish.
          </p>
        </div>

        <div>
          <h3>Navigation</h3>
          <div class="site-footer__links">
            {navItems.map((item) => (
              <a href={item.href}>{item.label}</a>
            ))}
          </div>
        </div>

        <div>
          <h3>Contact</h3>
          <div class="site-footer__links">
            <a href="tel:07549919442">07549 919 442</a>
            <a href="mailto:hello@keystonerenovations.co.uk">hello@keystonerenovations.co.uk</a>
            <span>Private homeowner renovations</span>
          </div>
        </div>
      </div>
    </footer>
  </main>

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.18 }
    );

    document.querySelectorAll('[data-animate]').forEach((element) => observer.observe(element));

    const menuToggle = document.querySelector('.menu-toggle');
    const mobileMenu = document.querySelector('#mobile-menu');

    if (menuToggle instanceof HTMLButtonElement && mobileMenu instanceof HTMLElement) {
      const closeMenu = () => {
        menuToggle.setAttribute('aria-expanded', 'false');
        mobileMenu.hidden = true;
        mobileMenu.classList.remove('is-open');
      };

      const openMenu = () => {
        menuToggle.setAttribute('aria-expanded', 'true');
        mobileMenu.hidden = false;
        mobileMenu.classList.add('is-open');
      };

      menuToggle.addEventListener('click', () => {
        const isOpen = menuToggle.getAttribute('aria-expanded') === 'true';
        if (isOpen) {
          closeMenu();
        } else {
          openMenu();
        }
      });

      mobileMenu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => closeMenu());
      });

      window.addEventListener('resize', () => {
        if (window.innerWidth > 1083) {
          closeMenu();
        }
      });
    }
  </script>
</MainLayout>
