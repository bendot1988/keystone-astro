---
import { Image } from 'astro:assets';
import heroInterior from '../assets/images/hero-interior.jpg';
---

<section id="top" class="bg-[#f8f5ef]">
  <div class="mx-auto grid min-h-[calc(100svh-5.3rem)] w-full max-w-[1440px] items-center gap-12 px-6 py-16 sm:px-10 sm:py-20 lg:grid-cols-[minmax(0,0.92fr)_minmax(320px,1fr)] lg:gap-20 lg:px-16 lg:py-28 xl:px-24 xl:py-36">
    <div class="max-w-2xl">
      <p class="mb-6 text-[0.75rem] font-semibold uppercase tracking-[0.28em] text-[#8d7c63] sm:mb-8">
        Keystone Renovations
      </p>

      <h1
        class="max-w-[10ch] text-[clamp(3.5rem,9vw,6.75rem)] font-semibold leading-[0.92] tracking-[-0.045em] text-[#171513]"
        style="font-family: 'Cormorant Garamond', serif;"
      >
        We bring your renovations to life.
      </h1>

      <p class="mt-8 max-w-xl text-lg leading-9 text-[#4f4942] sm:mt-10 sm:text-[1.2rem]">
        High-quality, reliable property improvements. From chimney pot to cellar, back gate to front gate.
      </p>

      <div class="mt-10 sm:mt-12">
        <a
          href="#contact"
          class="inline-flex items-center justify-center rounded-full border border-[#171513] px-7 py-3 text-sm font-semibold text-[#171513] transition hover:-translate-y-0.5 hover:bg-[#171513] hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#171513] focus-visible:ring-offset-4"
        >
          Discuss your project
        </a>
      </div>
    </div>

    <div class="relative">
      <div class="absolute -inset-6 hidden rounded-[2rem] border border-[#d8d0c3] lg:block"></div>
      <div class="relative overflow-hidden rounded-[1.75rem] bg-white shadow-[0_30px_80px_rgba(23,21,19,0.08)]">
        <Image
          src={heroInterior}
          alt="A clean, finished interior with soft natural light and refined contemporary detailing"
          widths={[720,960,1280]}
          sizes="(min-width: 1280px) 42rem, (min-width: 1024px) 48vw, 100vw"
          class="h-full min-h-[420px] w-full object-cover"
          loading="eager"
          format="webp"
          quality={90}
        />
      </div>
    </div>
  </div>
</section>
